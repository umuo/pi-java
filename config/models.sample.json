{
  // ==============================================================================
  // Pi Coding Agent Java Edition - 模型配置示例 (Models Configuration Sample)
  // ==============================================================================
  // 使用方法：
  // 1. 将此文件复制到项目根目录下： cp config/models.sample.json .pi/agent/models.json
  //    或者复制到用户全局目录：    cp config/models.sample.json ~/.pi/agent/models.json
  // 2. 根据实际使用的 AI 模型网关或本地模型，修改下方配置即可。
  // ==============================================================================

  "providers": {
    // ----------------------------------------------------------------------------
    // 示例 1：对接 OpenAI 官方或第三方 API 中转网关 (API Proxy / One API / New API)
    // ----------------------------------------------------------------------------
    "openai": {
      // 覆盖默认的请求网关地址（如使用中转服务，将 URL 改为中转网关地址）
      "baseUrl": "https://api.openai.com/v1",
      // 可选：在此处直接配置 API Key（也可在 auth.json 或环境变量 OPENAI_API_KEY 中配置）
      "apiKey": "sk-your-openai-api-key-here",
      // 针对特定模型的参数微调
      "modelOverrides": {
        "gpt-4o": {
          "headers": {
            "X-Custom-Header": "pi-java-client"
          }
        }
      }
    },

    // ----------------------------------------------------------------------------
    // 示例 2：对接 Anthropic Claude 官方或中转代理
    // ----------------------------------------------------------------------------
    "anthropic": {
      "baseUrl": "https://api.anthropic.com",
      "apiKey": "sk-ant-your-api-key-here"
    },

    // ----------------------------------------------------------------------------
    // 示例 3：对接本地大模型 Ollama (Local Ollama / vLLM / DeepSeek)
    // ----------------------------------------------------------------------------
    "custom-ollama": {
      "name": "Ollama Local Models",
      // Ollama 本地默认服务端口
      "baseUrl": "http://localhost:11434/v1",
      // Ollama 兼容 OpenAI 格式协议，apiKey 填任意非空字符串即可
      "apiKey": "ollama-local",
      "models": [
        {
          "id": "qwen2.5:14b",
          "name": "Qwen 2.5 14B (Local)",
          "api": "openai-completions",
          "contextWindow": 32768,
          "maxOutputTokens": 8192,
          "supportsTools": true,
          "supportsImages": false
        },
        {
          "id": "deepseek-coder-v2:16b",
          "name": "DeepSeek Coder v2 16B (Local)",
          "api": "openai-completions",
          "contextWindow": 65536,
          "maxOutputTokens": 8192,
          "supportsTools": true,
          "supportsImages": false
        }
      ]
    },

    // ----------------------------------------------------------------------------
    // 示例 4：对接第三方兼容 API（如 DeepSeek 官方 API）
    // ----------------------------------------------------------------------------
    "deepseek": {
      "name": "DeepSeek Official",
      "baseUrl": "https://api.deepseek.com/v1",
      "apiKey": "sk-your-deepseek-api-key",
      "models": [
        {
          "id": "deepseek-chat",
          "name": "DeepSeek V3",
          "api": "openai-completions",
          "contextWindow": 65536,
          "maxOutputTokens": 8192,
          "supportsTools": true
        },
        {
          "id": "deepseek-reasoner",
          "name": "DeepSeek R1 (Reasoning)",
          "api": "openai-completions",
          "contextWindow": 65536,
          "maxOutputTokens": 8192,
          "supportsTools": false
        }
      ]
    }
  }
}
